NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Optional: set to "true" to restrict sign-in to emails saved under Users (Firestore settings/allowedUsers).
# If unset or not "true", any Google account can sign in (default).
# NEXT_PUBLIC_USER_ALLOWLIST_ENABLED=true

# Optional when allowlist is enforced: comma-separated emails that always pass (recovery / owners).
# NEXT_PUBLIC_SCHEDULER_ADMIN_EMAILS=you@company.com,other@company.com

# Google Calendar sync (server): shared calendar resource id; share that calendar with the service account email.
# GOOGLE_CALENDAR_ID=c_...@group.calendar.google.com

# Service account JSON (same GCP project as Firebase). Enable Calendar API; use for Admin SDK + Calendar API.
# Paste the full JSON on one line or use GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL + GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY instead.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Alternative to GOOGLE_SERVICE_ACCOUNT_JSON (e.g. Vercel-friendly escaping):
# GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=firebase-adminsdk-xxxxx@project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SERVICE_ACCOUNT_PROJECT_ID=your_project_id
