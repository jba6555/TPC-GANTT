rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Activity/history log (timeline edits write here). If production rules list only
    // projects/tasks, add this block there too or keep the catch-all below.
    match /changelog/{entryId} {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
